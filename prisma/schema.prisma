// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  password      String
  avatarUrl     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  teams         Team[]      @relation("TeamMembers")
  assignedTasks Task[]
  createdTasks  Task[]      @relation("TaskCreator")
  comments      Comment[]
  timeEntries   TimeEntry[]
}

model Team {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  members   User[]    @relation("TeamMembers")
  projects  Project[]
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  status      String       @default("In Progress") // e.g., "In Progress", "Completed"
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id])
  tasks       Task[]
  taskStatuses TaskStatus[]
}

model Task {
  id            String      @id @default(cuid())
  title         String
  description   String?     // Rich text content stored as HTML
  status        String      @default("To Do") // e.g., "To Do", "In Progress", "Done" - will be deprecated in favor of statusId
  statusId      String?     // Reference to TaskStatus
  taskStatus    TaskStatus? @relation(fields: [statusId], references: [id])
  priority      String?     // e.g., "Low", "Medium", "High"
  dueDate       DateTime?
  estimatedHours Float?     // Estimated time in hours (0.5 = 30 minutes)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id])
  assigneeId    String?
  assignee      User?       @relation(fields: [assigneeId], references: [id])
  createdById   String?     // Author of the task (optional for existing tasks)
  createdBy     User?       @relation("TaskCreator", fields: [createdById], references: [id])
  subtasks      Subtask[]
  comments      Comment[]
  timeEntries   TimeEntry[]
  images        TaskImage[]
  todos         Todo[]
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskStatus {
  id        String   @id @default(cuid())
  name      String   // e.g., "To Do", "In Progress", "Done", "Review", etc.
  color     String   @default("#6B7280") // Hex color for the status
  order     Int      // Order of the status in the board (0, 1, 2, etc.)
  isDefault Boolean  @default(false) // Whether this is the default status for new tasks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  tasks     Task[]

  @@unique([projectId, name]) // Ensure unique status names per project
  @@unique([projectId, order]) // Ensure unique order per project
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  isCompleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
}

model TaskImage {
  id        String   @id @default(cuid())
  filename  String   // Original filename
  url       String   // Path to the stored image
  mimeType  String   // Image MIME type
  size      Int      // File size in bytes
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id          String   @id @default(cuid())
  hours       Float    // Time spent in hours (0.5 = 30 minutes)
  description String?  // Optional description of work done
  date        DateTime @default(now()) // When the work was done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  userId      String   // Who logged the time
  user        User     @relation(fields: [userId], references: [id])
}
